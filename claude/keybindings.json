{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "ModelPicker",
      "bindings": {
        "ctrl+h": "modelPicker:decreaseEffort",
        "ctrl+l": "modelPicker:increaseEffort"
      }
    },
    {
      "context": "Select",
      "bindings": {
        "ctrl+j": "select:next",
        "ctrl+k": "select:previous"
      }
    }
  ]
}
