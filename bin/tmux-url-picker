#!/usr/bin/env bash
# tmux URL picker: extract URLs from pane, select with fzf, open or copy.
# Replaces fzf-tmux-url plugin to handle URLs that wrap across lines.

# Capture the visible pane and rebuild URLs that were wrapped across rows. tmux paints each
# wrapped row as an independent line (TUIs like the Codex/omp login screen also re-indent
# every row), so -J cannot rejoin them. Strip each line's surrounding whitespace, then
# concatenate a line onto the previous one only when it has no internal spaces and does not
# start a new URL -- i.e. it is the no-space tail of a wrapped URL. URLs never contain
# spaces, so this rejoins a split URL without gluing on trailing prose (e.g. "Click here to
# login"), and works regardless of the wrap column. The final awk splits any
# directly-adjacent URLs back apart.
content=$(tmux capture-pane -p |
    awk '{ s=$0; sub(/^[ \t]+/,"",s); sub(/[ \t]+$/,"",s)
           if (acc!="" && s!="" && s !~ /[ \t]/ && s !~ /^(https?|ftp|file):\/\//) acc=acc s
           else { if (acc!="") print acc; acc=s } }
         END { if (acc!="") print acc }' |
    awk '{gsub(/(https?|ftp|file):\/\//,"\n&");print}')

url_regex='(https?|ftp|file):/?//[-A-Za-z0-9+&@#/%?=~_|!:,.;]*[-A-Za-z0-9+&@#/%=~_|]'

urls=$(echo "$content" | grep -oE "$url_regex")
wwws=$(echo "$content" | grep -oE '(https?://)?www\.[a-zA-Z](-?[a-zA-Z0-9])+\.[a-zA-Z]{2,}(/\S+)*' | grep -vE '^https?://' | sed 's/^\(.*\)$/http:\/\/\1/')
ips=$(echo "$content" | grep -oE '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}(:[0-9]{1,5})?(/\S+)*' | sed 's/^\(.*\)$/http:\/\/\1/')
gits=$(echo "$content" | grep -oE '(ssh://)?git@\S*' | sed 's/:/\//g' | sed 's/^\(ssh\/\/\/\)\{0,1\}git@\(.*\)$/https:\/\/\2/')

items=$(printf '%s\n' "$urls" "$wwws" "$ips" "$gits" |
    grep -v '^$' |
    awk '!seen[$0]++' |
    # Drop any candidate that is a strict prefix of a longer one, so a truncated
    # fragment (e.g. from a mis-measured multibyte row) never shadows the full URL.
    awk '{l[NR]=$0} END{for(i=1;i<=NR;i++){k=1;for(j=1;j<=NR;j++)if(i!=j&&length(l[j])>length(l[i])&&substr(l[j],1,length(l[i]))==l[i]){k=0;break}if(k)print l[i]}}' |
    nl -w3 -s '  '
)

[ -z "$items" ] && tmux display 'No URLs found' && exit

chosen=$(fzf-tmux -w 100% -h 50% --multi -0 --no-preview --wrap <<< "$items" | awk '{print $2}')
[ -z "$chosen" ] && exit

while IFS= read -r url; do
    if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ]; then
        if tmux set-buffer -w "$url" 2>/dev/null; then
            tmux display-message "Copied URL to clipboard"
        else
            encoded=$(printf '%s' "$url" | base64 | tr -d '\n')
            printf '\ePtmux;\e\e]52;c;%s\a\e\\' "$encoded"
            tmux display-message "Copied URL to clipboard (OSC 52)"
        fi
    else
        open "$url"
    fi
done <<< "$chosen"
