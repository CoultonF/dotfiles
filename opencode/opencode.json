{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "plan",
  "share": "manual",
  "permission": {
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "git push*": "ask",
      "gh pr merge*": "ask",
      "git reset --hard*": "ask",
      "git clean*": "ask",
      "gh repo delete*": "ask"
    },
    "mcp-postgres_*": "allow"
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  }
}
