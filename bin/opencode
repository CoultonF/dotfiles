#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
    local target="$1"
    if command -v readlink >/dev/null 2>&1; then
        readlink -f "$target" 2>/dev/null && return 0
    fi
    printf '%s\n' "$target"
}

find_raw_opencode() {
    local self resolved_self candidate resolved_candidate
    self="$(resolve_path "${BASH_SOURCE[0]:-$0}")"
    while IFS= read -r candidate; do
        [[ -n "$candidate" ]] || continue
        resolved_candidate="$(resolve_path "$candidate")"
        [[ "$resolved_candidate" == "$self" ]] && continue
        [[ "$resolved_candidate" == *"/opentmux"* ]] && continue
        printf '%s\n' "$candidate"
        return 0
    done < <(which -a opencode 2>/dev/null || true)

    if [[ -x "$HOME/.nix-profile/bin/opencode" ]]; then
        resolved_self="$(resolve_path "$HOME/.nix-profile/bin/opencode")"
        if [[ "$resolved_self" != "$self" ]]; then
            printf '%s\n' "$HOME/.nix-profile/bin/opencode"
            return 0
        fi
    fi

    return 1
}

raw_opencode="$(find_raw_opencode || true)"
parent_cmd="$(ps -p "$PPID" -o command= 2>/dev/null || true)"

if [[ "${1:-}" == "attach" || -n "${OPENCODE_PORT:-}" || "$parent_cmd" == *opentmux* ]]; then
    if [[ -n "$raw_opencode" ]]; then
        exec "$raw_opencode" "$@"
    fi
    echo "opentmux invoked opencode, but no raw opencode binary was found." >&2
    exit 1
fi

if command -v opentmux >/dev/null 2>&1; then
    exec opentmux "$@"
fi

if [[ -n "$raw_opencode" ]]; then
    echo "opentmux is not installed; falling back to the raw opencode binary." >&2
    exec "$raw_opencode" "$@"
fi

echo "Neither opentmux nor the raw opencode binary is available." >&2
exit 1
